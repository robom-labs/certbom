{
  "name": "@certbom/web",
  "version": "0.8.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit && vite build && node ../../scripts/verify-family-build.mjs src/generated/robom-family ../../family.lock.json dist/robom-family",
    "preview": "vite preview --host 0.0.0.0",
    "test:e2e": "pnpm build && playwright test"
  },
  "dependencies": {
    "@certbom/core": "workspace:*",
    "@supabase/supabase-js": "2.110.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "workbox-window": "7.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "happy-dom": "20.10.6",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
