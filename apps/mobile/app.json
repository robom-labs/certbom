{
  "expo": {
    "name": "자격증봄",
    "slug": "certbom",
    "version": "0.8.0",
    "description": "다양한 시험을 오프라인에서 찾고 공식 일정·관심 시험·준비 알림을 확인하는 자격증봄",
    "platforms": [
      "ios",
      "android"
    ],
    "scheme": "certbom",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "kr.robom.certbom",
      "buildNumber": "6",
      "supportsTablet": true,
      "associatedDomains": []
    },
    "android": {
      "package": "kr.robom.certbom",
      "versionCode": 6,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E7F4EB"
      },
      "intentFilters": []
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#18794e",
          "defaultChannel": "certbom-reminders"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],
    "owner": "robom-labs",
    "extra": {
      "eas": {
        "projectId": "a9e8c88b-638b-4bf6-881b-539a12915421"
      }
    }
  }
}
