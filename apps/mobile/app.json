{
  "expo": {
    "name": "자격증봄",
    "slug": "certbom",
    "version": "0.7.1",
    "description": "97개 시험을 오프라인에서 찾고 공식 일정·관심 시험·준비 알림을 확인하는 자격증봄",
    "platforms": [
      "ios",
      "android"
    ],
    "scheme": "certbom",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "kr.robom.certbom",
      "buildNumber": "5",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:robom.kr"
      ]
    },
    "android": {
      "package": "kr.robom.certbom",
      "versionCode": 5,
      "predictiveBackGestureEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E7F4EB"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "robom.kr",
              "pathPrefix": "/get/certbom"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#18794e",
          "defaultChannel": "certbom-reminders"
        }
      ]
    ]
  }
}
